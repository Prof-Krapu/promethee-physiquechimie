# ============================================================
#  Prométhée — .gitignore
# ============================================================

# ── Secrets & configuration locale ──────────────────────────
.env
*.env

# ── Base de données ──────────────────────────────────────────
*.db
*.db-shm
*.db-wal

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Distribution / packaging ─────────────────────────────────
build/
dist/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/
*.whl

# ── Environnements virtuels ──────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Tests & couverture ───────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# ── IDEs ─────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── macOS ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Fichiers temporaires ─────────────────────────────────────
*.tmp
*.bak
*.orig

# ── Outputs générés par Prométhée ────────────────────────────
exports/
output/

# ── Outils maison ────────────────────────────────────────────
git_helper.py
